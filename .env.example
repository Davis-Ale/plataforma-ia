# ===========================================
# AMBIENTE
# ===========================================
NODE_ENV=development

# ===========================================
# BANCO DE DADOS
# ===========================================
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=plataforma
DB_HOST=localhost
DB_PORT=5434
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/plataforma?schema=public

# ===========================================
# REDIS
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380

# ===========================================
# JWT / AUTH
# ===========================================
JWT_SECRET=sua-chave-secreta-aqui-trocar-em-producao
JWT_EXPIRES_IN=7d

# ===========================================
# API
# ===========================================
API_PORT=3000
API_PREFIX=api/v1

# ===========================================
# FRONTEND
# ===========================================
WEB_PORT=3001
ADMIN_PORT=3002
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# ===========================================
# IA
# ===========================================
AI_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ===========================================
# STORAGE (S3 / R2)
# ===========================================
STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=sa-east-1
AWS_BUCKET=plataforma-files

# ===========================================
# SENTRY (produção)
# ===========================================
SENTRY_DSN=

# ===========================================
# BETTERSTACK (produção)
# ===========================================
BETTERSTACK_TOKEN=
