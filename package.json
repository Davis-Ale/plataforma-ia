{
  "name": "plataforma-ia",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma multi-tenant de automacao operacional com IA",
  "author": "Davis Alexandre Farias",
  "license": "PROPRIETARY",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.4.0",
  "scripts": {
    "dev": "pnpm --filter @plataforma/api dev",
    "dev:web": "pnpm --filter @plataforma/web dev",
    "dev:admin": "pnpm --filter @plataforma/admin dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @plataforma/database generate",
    "db:migrate": "pnpm --filter @plataforma/database migrate:dev",
    "db:push": "pnpm --filter @plataforma/database push",
    "db:studio": "pnpm --filter @plataforma/database studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.5.0",
    "prettier": "^3.3.0",
    "eslint": "^9.5.0"
  }
}
