// ===========================================
// PRISMA SCHEMA - PLATAFORMA IA
// Base multi-tenant foundation
// ===========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum CompanyUserRole {
  OWNER
  ADMIN
  MEMBER
}

enum CompanyUserStatus {
  ACTIVE
  INVITED
  INACTIVE
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

model Company {
  id        String        @id @default(uuid())
  name      String
  legalName String?
  document  String?       @unique
  status    CompanyStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  users     CompanyUser[]
  customers Customer[]

  @@map("companies")
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  passwordHash String?
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  companies    CompanyUser[]

  @@map("users")
}

model CompanyUser {
  id        String            @id @default(uuid())
  companyId String
  userId    String
  role      CompanyUserRole   @default(MEMBER)
  status    CompanyUserStatus @default(ACTIVE)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  company   Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([userId])
  @@map("company_users")
}

model Customer {
  id        String         @id @default(uuid())
  companyId String         @map("company_id")
  name      String
  email     String?
  phone     String?
  document  String?
  status    CustomerStatus @default(ACTIVE)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, document])
  @@index([companyId])
  @@map("customers")
}

model FoundationCheck {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  @@map("_foundation_checks")
}
